GOOGLE_AI_API_KEY=your_google_ai_key_here
GEMMA_ONLINE_MODEL=models/gemma-4-26b-a4b-it

OLLAMA_BASE_URL=http://localhost:11434
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
GEMMA_OFFLINE_MODEL=gemma4:e4b-it
OLLAMA_HEALTH_TIMEOUT_SECONDS=1.0
OLLAMA_GENERATION_TIMEOUT_SECONDS=180.0

CHROMA_PATH=./data/chroma
RAG_VISUAL_ASSETS_PATH=./data/page_images
RAG_TEXT_EMBEDDING_PROVIDER=fastembed
RAG_TEXT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_IMAGE_EMBEDDING_PROVIDER=fastembed-clip
RAG_IMAGE_EMBEDDING_MODEL=Qdrant/clip-ViT-B-32-vision
RAG_IMAGE_TEXT_EMBEDDING_MODEL=Qdrant/clip-ViT-B-32-text
DB_PATH=./data/imciflow.db

WHISPER_MODEL_NAME=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
AUDIO_TEMP_DIR=./data/audio_tmp
AUDIO_MAX_FILE_SIZE_BYTES=26214400

VIDEO_TEMP_DIR=./data/video_tmp
VIDEO_MAX_FILE_SIZE_BYTES=83886080
VIDEO_MAX_DURATION_SECONDS=120.0

APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173,https://gemma-4-hackathon.vercel.app
